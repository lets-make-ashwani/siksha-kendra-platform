# Database Configuration
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/siksha_kendra?retryWrites=true&w=majority"

# Application Config
PORT=5000
NODE_ENV=development

# Frontend Config (Used by Vite)
VITE_API_URL=http://localhost:5000
FRONTEND_URL=https://your-frontend-project.vercel.app

# Super Admin Credentials (set these safely in Render Environment Variables)
SUPER_ADMIN_EMAIL="admin@sikshakendra.com"
SUPER_ADMIN_PASSWORD="YourSecurePassword123!"

# Authentication
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email / Resend
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="noreply@sikshakendra.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"